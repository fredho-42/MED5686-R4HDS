author = {Jordana B. Cohen  and Nancy J. Brown  and Sherry-Ann Brown  and Susan Dent  and Daan C.H. van Dorst  and Sandra M. Herrmann  and Ninian N. Lang  and Gavin Y. Oudit  and Rhian M. Touyz  and null null },
title = "{Cancer Therapy–Related Hypertension: A Scientific Statement From the American Heart Association}",
