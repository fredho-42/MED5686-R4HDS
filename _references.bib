https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4728597/},
   year = {2016},
   type = {Journal Article}
}

@article{Azzato2009,
   author = {Azzato, E. M. and Greenberg, D. and Shah, M. and Blows, F. and Driver, K. E. and Caporaso, N. E. and Pharoah, P. D. P.},
   title = {Prevalent cases in observational studies of cancer survival: do they bias hazard ratio estimates?},
   journal = {British journal of cancer},
   volume = {100},
   number = {11},
   pages = {1806-1811},
   adsnote ={19401693[pmid]
PMC2695697[pmcid]
6605062[PII]},
   abstract = {Observational epidemiological studies often include prevalent cases recruited at various times past diagnosis. This left truncation can be dealt with in non-parametric (Kaplan-Meier) and semi-parametric (Cox) time-to-event analyses, theoretically generating an unbiased hazard ratio (HR) when the proportional hazards (PH) assumption holds. However, concern remains that inclusion of prevalent cases in survival analysis results inevitably in HR bias. We used data on three well-established breast cancer prognosticators - clinical stage, histopathological grade and oestrogen receptor (ER) status - from the SEARCH study, a population-based study including 4470 invasive breast cancer cases (incident and prevalent), to evaluate empirically the effectiveness of allowing for left truncation in limiting HR bias. We found that HRs of prognostic factors changed over time and used extended Cox models incorporating time-dependent covariates. When comparing Cox models restricted to subjects ascertained within six months of diagnosis (incident cases) to models based on the full data set allowing for left truncation, we found no difference in parameter estimates (P=0.90, 0.32 and 0.95, for stage, grade and ER status respectively). Our results show that use of prevalent cases in an observational epidemiological study of breast cancer does not bias the HR in a left truncation Cox survival analysis, provided the PH assumption holds true.},
   keywords = {Adult
Aged
Breast Neoplasms/*epidemiology/metabolism/pathology
Follow-Up Studies
Humans
Middle Aged
Models, Biological
Prevalence
Receptors, Estrogen/metabolism
Survival Rate
Time Factors},
   ISSN = {1532-1827
0007-0920},
   DOI = {10.1038/sj.bjc.6605062},
   url = {https://pubmed.ncbi.nlm.nih.gov/19401693
https://www.ncbi.nlm.nih.gov/pmc/articles/PMC2695697/},
   year = {2009},
   type = {Journal Article}
}

@article{Bair2013,
   author = {Bair, Eric},
   title = {Semi-supervised clustering methods},
   journal = {Wiley interdisciplinary reviews. Computational statistics},
   volume = {5},
   number = {5},
   pages = {349-361},
   adsnote ={24729830[pmid]
PMC3979639[pmcid]},
   abstract = {Cluster analysis methods seek to partition a data set into homogeneous subgroups. It is useful in a wide variety of applications, including document processing and modern genetics. Conventional clustering methods are unsupervised, meaning that there is no outcome variable nor is anything known about the relationship between the observations in the data set. In many situations, however, information about the clusters is available in addition to the values of the features. For example, the cluster labels of some observations may be known, or certain observations may be known to belong to the same cluster. In other cases, one may wish to identify clusters that are associated with a particular outcome variable. This review describes several clustering algorithms (known as "semi-supervised clustering" methods) that can be applied in these situations. The majority of these methods are modifications of the popular k-means clustering method, and several of them will be described in detail. A brief description of some other semi-supervised clustering algorithms is also provided.},
   keywords = {cluster analysis
high-dimensional data
machine learning
semi-supervised methods},
   ISSN = {1939-5108},
   DOI = {10.1002/wics.1270},
   url = {https://www.ncbi.nlm.nih.gov/pubmed/24729830
https://www.ncbi.nlm.nih.gov/pmc/articles/PMC3979639/},
   year = {2013},
   type = {Journal Article}
}

@article{Baron-Franco2017,
   author = {Baron-Franco, B. and McLean, G. and Mair, F. S. and Roger, V. L. and Guthrie, B. and Mercer, S. W.},
   title = {Comorbidity and polypharmacy in chronic heart failure: a large cross-sectional study in primary care},
   journal = {Br J Gen Pract},
   volume = {67},
   number = {658},
   pages = {e314-e320},
   adsnote ={1478-5242
Baron-Franco, Bosco
McLean, Gary
Mair, Frances S
