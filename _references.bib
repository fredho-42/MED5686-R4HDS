   author = {Loghmanpour, Natasha A. and Kormos, Robert L. and Kanwar, Manreet K. and Teuteberg, Jeffrey J. and Murali, Srinivas and Antaki, James F.},
   title = {A Bayesian Model to Predict Right Ventricular Failure Following Left Ventricular Assist Device Therapy},
