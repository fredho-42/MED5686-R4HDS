@article{Coiro2021,
   author = {Coiro, Stefano and Girerd, Nicolas and McMurray, John JV. and Pitt, Bertram and Swedberg, Karl and van Veldhuisen, Dirk J. and Lamiral, Zohra and Rossignol, Patrick and Zannad, Faiez},
