@article{Cleland2016,
  author = {Cleland, J. G. and Zhang, J. and Pellicori, P. and Dicken, B. and Dierckx, R. and Shoaib, A. and Wong, K. and Rigby, A. and Goode, K. and Clark, A. L.},
  title = {Prevalence and Outcomes of Anemia and Hematinic Deficiencies in Patients With Chronic Heart Failure},
  journal = {JAMA Cardiol},
