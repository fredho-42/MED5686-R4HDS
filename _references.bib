@article{Khan2007,
   author = {Khan, N. K. and Goode, K. M. and Cleland, J. G. and Rigby, A. S. and Freemantle, N. and Eastaugh, J. and Clark, A. L. and de Silva, R. and Calvert, M. J. and Swedberg, K. and Komajda, M. and Mareev, V. and Follath, F. and EuroHeart Failure Survey, Investigators},
   title = {Prevalence of {ECG} abnormalities in an international survey of patients with suspected or confirmed heart failure at death or discharge},
   journal = {Eur J Heart Fail},
   volume = {9},
   number = {5},
   pages = {491-501},
   
   abstract = {BACKGROUND: Most patients suspected of having heart failure (HF) will get a 12-lead electrocardiogram (ECG) but its utility for excluding HF or assisting in its management has rarely been investigated. METHODS: The EuroHeart Failure survey identified 11,327 patients hospitalised with a suspected diagnosis of HF from 115 hospitals in 24 countries. ECGs were obtained from 9315 patients, of whom 5934 had cardiac imaging tests. The utility of the ECG was assessed for excluding or diagnosing major structural heart disease (MSHD) or major left ventricular systolic dysfunction (MLVSD) and for therapeutic decision making. FINDINGS: MSHD was present in 70\% and MLVSD in 54\% of patients overall but in only 21\% and 5\%, respectively, if the ECG was entirely normal. However, <2\% of patients had a normal ECG. No single ECG characteristic identified a probability <25\% of MSHD or <20\% of MLVSD. Patients with QRS width >or=120 ms or anterior pathological Q-waves had a probability >80\% of MSHD and >70\% of MLVSD. Diagnostic models suggested that electrocardiographic criteria alone were not accurate for the diagnosis or exclusion of important heart disease in this population. However, 2468 patients (42\%) had an electrocardiographic finding that should be used to guide the choice of therapy. CONCLUSIONS: A normal ECG is rare in patients with suspected HF but has limited diagnostic value in this setting. The ECG has an important role in guiding therapy.},
