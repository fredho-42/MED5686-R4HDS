@article{Velanovich1994,
   author = {Velanovich, Vic},
   title = {Bayesian Analysis in the Diagnostic Process},
   journal = {American Journal of Medical Quality},
   volume = {9},
   number = {4},
   pages = {158-161},
   abstract = {A diagnosis is made by a process in which the physician gathers evidence. The physician uses this evidence to put the patient in a class of patients with a disease. Bayes' theorem quantifies the effects of the evidence in increasing the probability that the patient has the disease. This article will discuss the potential of Bayesian analysis for medical diagnosis. Applica tions of Bayesian analysis to the diagnostic process could improve the efficiency of this process.},
