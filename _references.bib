@article{Shameer2017,
   author = {Shameer, K. and Johnson, K. W. and Yahi, A. and Miotto, R. and Li, L. I. and Ricks, D. and Jebakaran, J. and Kovatch, P. and Sengupta, P. P. and Gelijns, S. and Moskovitz, A. and Darrow, B. and David, D. L. and Kasarskis, A. and Tatonetti, N. P. and Pinney, S. and Dudley, J. T.},
   title = {Predictive Modeling of Hospital Readmission Rates Using Electronic Medical Record-Wide Machine Learning: A Case-Study Using Mount Sinai Heart Failure Cohort},
   journal = {Pac Symp Biocomput},
   volume = {22},
   pages = {276-287},
   adsnote ={Shameer, Khader
Johnson, Kipp W
Yahi, Alexandre
Miotto, Riccardo
Li, L I
Ricks, Doran
Jebakaran, Jebakumar
Kovatch, Patricia
Sengupta, Partho P
Gelijns, Sengupta
Moskovitz, Alan
Darrow, Bruce
David, David L
Kasarskis, Andrew
Tatonetti, Nicholas P
