Sulfonamides/administration \& dosage
Survival Analysis
Torsemide},
  ISSN = {0002-9149 (Print)
0002-9149 (Linking)},
  DOI = {10.1016/j.amjcard.2005.12.072},
  url = {https://www.ncbi.nlm.nih.gov/pubmed/16765130},
  year = {2006},
  type = {Journal Article}
}

