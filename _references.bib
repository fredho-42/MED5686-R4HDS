@article{Emdin2007,
  author = {Emdin, M. and Passino, C. and Prontera, C. and Fontana, M. and Poletti, R. and Gabutti, A. and Mammini, C. and Giannoni, A. and Zyw, L. and Zucchelli, G. and Clerico, A.},
  title = {Comparison of brain natriuretic peptide (BNP) and amino-terminal ProBNP for early diagnosis of heart failure},
  journal = {Clin Chem},
  volume = {53},
  number = {7},
  pages = {1289-97},
  adsnote ={Emdin, Michele
Passino, Claudio
Prontera, Concetta
Fontana, Marianna
Poletti, Roberta
